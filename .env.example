# KAVACH-09 — Environment Configuration
# =======================================
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ─── TELEGRAM (REQUIRED) ─────────────────────────────────────────
# Get bot token from @BotFather: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=

# Your personal chat ID — talk to @userinfobot to get yours
TELEGRAM_CHAT_ID=


# ─── AI PROVIDER (REQUIRED for /explain and /why) ────────────────
# PRIMARY: Groq — free, fast, generous limits (14k req/day)
# Get a free key: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# FALLBACK: Google Gemini free tier (optional)
# Get a free key: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash


# ─── OPTIONAL: CoinGlass API (free tier) ─────────────────────────
# Without this, bot falls back to Binance public funding rates.
# Get a free key: https://www.coinglass.com/SwitchApi
COINGLASS_API_KEY=


# ─── OPTIONAL: SoSoValue API ─────────────────────────────────────
# Without this, ETF data may be unavailable (Binance fallback only).
SOSOVALUE_API_KEY=


# ─── OPTIONAL: Database path override ────────────────────────────
# Default: ./kavach09.db (relative to project root)
# KAVACH_DB_PATH=/var/lib/kavach09/kavach09.db